{
  "name": "ikihsjs",
  "version": "0.1.0",
  "private": false,
  "description": "Native Node.js syntax highlighting — Shiki-compatible API, Rust-powered performance",
  "keywords": [
    "highlighter",
    "napi",
    "rust",
    "shiki",
    "syntax-highlighting",
    "textmate"
  ],
  "homepage": "https://github.com/carlosedujs/ikihs",
  "bugs": {
    "url": "https://github.com/carlosedujs/ikihs/issues"
  },
  "license": "MIT",
  "author": "Ikihs contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlosedujs/ikihs"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "shiki-types.d.ts",
    "ikihsjs.*.node"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./shiki-types": {
      "types": "./shiki-types.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "test": "node --import tsx --test __test__/*.spec.ts",
    "test:js": "node --test __test__/*.spec.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "tsx": "^4"
  },
  "napi": {
    "binaryName": "ikihsjs",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 20"
  }
}
